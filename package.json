{
  "name": "freemium",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "client": "npm start --prefix client",
    "build": "npm run build --prefix client",
    "heroku-postbuild": "npm install --include=dev --prefix client && npm run build --prefix client",
    "lint": "eslint server/ && npm run lint --prefix client",
    "test": "npm run lint",
    "install-all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "mongoose": "^8.10.0",
    "redis": "^4.7.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "nodemon": "^3.1.9"
  }
}
